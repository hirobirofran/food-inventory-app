# =====================================================================
# Vercel デプロイ時の運用ルール
# =====================================================================
# このファイル内のすべての変数を Vercel の Environment Variables に投入
# する際、必ず「Sensitive」マークを ON にする（NEXT_PUBLIC_* は除く）。
# Sensitive マーク付きの env はインシデント時に「読み取り不能」な保管に
# なる。詳細は docs/KNOWLEDGE.md の 2026-04-21 セッションを参照。
# =====================================================================

# Google Sheets
GOOGLE_SPREADSHEET_ID=（スプレッドシートIDをここに）
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@your-project.iam.gserviceaccount.com
# JSONキーの private_key フィールドの値（-----BEGIN PRIVATE KEY----- から）
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gemini AI API
GEMINI_API_KEY=（Google AI Studio から取得したAPIキーをここに）

# 環境識別（デモ環境の場合のみ設定）
# NEXT_PUBLIC_* はクライアントに露出する公開値なので Sensitive マーク不要
# NEXT_PUBLIC_APP_ENV=demo

# 認証（家族共有パスワードゲート）
# SITE_PASSWORD は自分で決める。AUTH_COOKIE_SECRET は以下で生成した 64 文字 hex を貼り付け：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SITE_PASSWORD=（家族共有パスワード）
AUTH_COOKIE_SECRET=（ランダム 64 文字の hex）

# デモ環境のスプレッドシート ID（scripts/seed-demo.ts 用。本番環境のアプリでは未使用）
# 本番の GOOGLE_SPREADSHEET_ID とは必ず異なる値にする
DEMO_SHEET_ID=（デモ用スプレッドシートID）
